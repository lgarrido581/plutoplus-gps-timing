# Build output (firmware images, logs, extracted artifacts) — regenerated by the build
output/

# Local source cache / Docker bind dirs
src-cache/

# Downloaded host tools (e.g. dfu-util binaries) — see README for how to fetch
tools/*
!tools/*.ps1
!tools/make-uboot-env.py
!tools/smoke_test.py

# Exported/generated LibreSDR Vivado workspace
output/libresdr-hdl/
*.xpr
*.xsa
*.bit
*.jou
*.str
.Xil/
__pycache__/
*.py[cod]

# Logs
*.log
build-*.out
build-*.err
build-*.pid

# Local scratch backups (e.g. CHANGELOG_backup.md) — not part of the repo
*_backup.md

# Firmware artifacts if produced outside output/
*.frm
*.dfu

# Claude Code / editor / OS local files
.claude/
.vscode/
.idea/
.DS_Store
Thumbs.db

# Secrets — never commit (PATs, keys, env)
token
*.pat
*.key
.env
.netrc
